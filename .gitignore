# Barq C++ SDK
# Build stack: CMake + Conan + vcpkg (ports/), Catch2, Doxygen.

# --- Build output directories ---
build/
build-*/
cmake-build-*/
out/
install/

# --- CMake ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
CPackConfig.cmake
CPackSourceConfig.cmake
install_manifest*.txt
compile_commands.json
_deps/
Testing/
# Generated by `conan install`; CMakePresets.json is tracked.
CMakeUserPresets.json

# --- Conan ---
conan.lock
conanbuild.*
conanrun.*
conaninfo.txt
conan_toolchain.cmake
conandeps*.cmake
graph_info.json
.conan/

# --- vcpkg (keep ports/, ignore installed output) ---
vcpkg_installed/
/vcpkg/

# --- Compiled objects, libraries and executables ---
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.gch
*.pch

# --- Test & coverage output ---
*.gcno
*.gcda
*.gcov
*.profraw
*.profdata
lcov.info
/coverage/

# --- Documentation (Doxygen output -> ./docs/) ---
/docs/html/
/docs/latex/
/docs/xml/

# --- Apple / Swift / Xcode ---
/.build
/Packages
/*.xcodeproj
/.swiftpm
xcuserdata/
DerivedData/
Package.resolved

# --- Qt demo/example apps ---
examples/*.pro.user

# --- Editors & IDEs ---
.idea/
.vscode/
.vs/
.cache/
.clangd/
*.swp
*~

# --- OS files ---
.DS_Store
._*
Thumbs.db
Desktop.ini

# --- Project-specific generated sources ---
barq-core/src/barq/parser/generated/
